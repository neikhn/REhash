{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "REhash",
  "version": "0.1.0",
  "identifier": "com.rehash.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "REhash — Video Hash Modifier",
        "width": 560,
        "height": 680,
        "minWidth": 480,
        "minHeight": 580,
        "center": true,
        "dragDropEnabled": true,
        "decorations": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
